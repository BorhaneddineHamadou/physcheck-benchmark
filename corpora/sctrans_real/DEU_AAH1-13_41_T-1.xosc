    <Story name="mystory">
      <Act name="my_act">
        <ManeuverGroup maximumExecutionCount="1" name="Npc181ManeuverGroup">
          <Actors selectTriggeringEntities="false">
            <EntityRef entityRef="Npc181" />
          </Actors>
          <Maneuver name="Npc181_maneuver">
            <Event name="Npc181FollowTrajectory" priority="overwrite">
              <Action name="Npc181FollowTrajectory">
                <PrivateAction>
                  <RoutingAction>
