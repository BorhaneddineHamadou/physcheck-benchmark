    <Story name="mystory">
      <Act name="my_act">
        <ManeuverGroup maximumExecutionCount="1" name="Npc152ManeuverGroup">
          <Actors selectTriggeringEntities="false">
            <EntityRef entityRef="Npc152" />
          </Actors>
          <Maneuver name="Npc152_maneuver">
            <Event name="Npc152FollowTrajectory" priority="overwrite">
              <Action name="Npc152FollowTrajectory">
                <PrivateAction>
