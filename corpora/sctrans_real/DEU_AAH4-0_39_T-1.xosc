    <Story name="mystory">
      <Act name="my_act">
        <ManeuverGroup maximumExecutionCount="1" name="Npc260ManeuverGroup">
          <Actors selectTriggeringEntities="false">
            <EntityRef entityRef="Npc260" />
          </Actors>
          <Maneuver name="Npc260_maneuver">
            <Event name="Npc260FollowTrajectory" priority="overwrite">
              <Action name="Npc260FollowTrajectory">
                <PrivateAction>
                  <RoutingAction>
                    <AssignRouteAction>
                      <Route closed="false" name="Npc260route">
