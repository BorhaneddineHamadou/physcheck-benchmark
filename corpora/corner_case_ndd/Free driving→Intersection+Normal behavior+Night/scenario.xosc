                                                    <WorldPosition h="0.000000" p="0" r="0" x="9.756" y="62.43" z="0"/>
                                                </Position>
                                            </Vertex>
                                            <Vertex time="16">
                                                <Position>
                                                    <WorldPosition h="0.000000" p="0" r="0" x="9.778" y="62.43" z="0"/>
                                                </Position>
                                            </Vertex>
                                        </Polyline>
                                    </Shape>
                                </Trajectory>
                            </FollowTrajectoryAction>
                        </RoutingAction>
                    </PrivateAction>
                </Private>
            </Actions>
        </Init>
        <Story name="EmptyStory">
            <Act name="EmptyAct">
                <ManeuverGroup maximumExecutionCount="1" name="EmptyGroup">
                    <Actors selectTriggeringEntities="false"/>
                </ManeuverGroup>
                <StartTrigger>
                    <ConditionGroup>
                        <Condition conditionEdge="none" delay="0" name="SimulationStart">
                            <ByValueCondition>
                                <SimulationTimeCondition rule="greaterOrEqual" value="0"/>
                            </ByValueCondition>
                        </Condition>
                    </ConditionGroup>
                </StartTrigger>
            </Act>
        </Story>
        <StopTrigger>
            <ConditionGroup>
                <Condition conditionEdge="none" delay="0" name="">
                    <ByValueCondition>
                        <SimulationTimeCondition rule="greaterOrEqual" value="60"/>
                    </ByValueCondition>
                </Condition>
            </ConditionGroup>
            <ConditionGroup>
                <Condition conditionEdge="none" delay="0" name="">
                    <ByEntityCondition>
                        <TriggeringEntities triggeringEntitiesRule="any">
                            <EntityRef entityRef="vehicle"/>
                            <EntityRef entityRef="vehicle2"/>
                        </TriggeringEntities>
                        <EntityCondition>
                            <CollisionCondition>
                                <ByType type="vehicle"/>
                            </CollisionCondition>
                        </EntityCondition>
                    </ByEntityCondition>
                </Condition>
            </ConditionGroup>
        </StopTrigger>
    </Storyboard>
</OpenSCENARIO>